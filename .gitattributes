# The DLL C++ source is published for transparency/forks, but should NOT be in the
# distributed mod archive (`git archive` / release zip) — end users only need the built DLL.
dll-source/ export-ignore
dll-source/** export-ignore

# FOMOD installer source/scaffold — used to build the installer archive, not part of the
# plain data-root mod files.
fomod-src/ export-ignore
fomod-src/** export-ignore
